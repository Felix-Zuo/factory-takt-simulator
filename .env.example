# The browser app remains local-first and needs no secret. These variables are
# read only by `npm run gateway` from a local `.env.local` file.

INDUSTRIAL_GATEWAY_HOST=127.0.0.1
INDUSTRIAL_GATEWAY_PORT=8787
INDUSTRIAL_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
INDUSTRIAL_MAX_SSE_CLIENTS=32

# Required before an MES/SCADA source can push normalized snapshots.
INDUSTRIAL_INGEST_TOKEN=replace-with-a-long-random-token

# Optional Ignition Web Dev polling adapter. Prefer HTTPS in routed networks.
IGNITION_SNAPSHOT_URL=
IGNITION_BEARER_TOKEN=
IGNITION_POLL_MS=1000

# Physical commands are off by default. Enabling them also requires a bounded
# asset allowlist, operator token, downstream adapter, and exact confirmation.
INDUSTRIAL_ALLOW_COMMANDS=false
INDUSTRIAL_COMMAND_ASSETS=
INDUSTRIAL_OPERATOR_TOKEN=
MES_COMMAND_URL=
MES_COMMAND_TOKEN=

# Optional bounded engineering assistant. The key never enters browser code.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ALLOW_CUSTOM_BASE_URL=false
AI_MAX_OUTPUT_TOKENS=700
AI_DAILY_TOKEN_BUDGET=25000
AI_SESSION_CALLS_PER_HOUR=6
AI_TIMEOUT_MS=30000
AI_CACHE_TTL_MS=600000
